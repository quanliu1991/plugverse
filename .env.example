# PlugVerse 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 运行环境 (development|production)
ENV=production

# 服务配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 存储配置
STORAGE_PATH=./output
MAX_STORAGE_SIZE=10GB

# 数据库配置（可选）
# DATABASE_URL=postgresql://plugverse:password@localhost:5432/plugverse
DATABASE_URL=sqlite:///./data/plugverse.db

# Redis 配置（可选）
# REDIS_URL=redis://localhost:6379/0

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
API_KEY_PREFIX=plugverse_

# 插件配置
PLUGINS_DIR=./plugins
AUTO_LOAD_PLUGINS=true

# 前端配置
STATIC_DIR=./static
FRONTEND_URL=http://localhost:3000
