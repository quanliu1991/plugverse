# PlugVerse 默认配置
# 复制为 default.yaml 使用

server:
  host: 0.0.0.0
  port: 8000
  debug: false
  workers: 4

storage:
  path: ./output
  max_size: 10GB
  cleanup_days: 30

plugins:
  auto_load: true
  directory: ./plugins
  timeout: 30

database:
  type: sqlite
  path: ./data/plugverse.db
  # 生产环境建议使用 PostgreSQL
  # type: postgresql
  # url: postgresql://user:pass@localhost:5432/plugverse

redis:
  enabled: false
  url: redis://localhost:6379/0

logging:
  level: INFO
  file: ./logs/app.log
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  max_size: 10MB
  backup_count: 5

security:
  secret_key: change-me-in-production
  api_key_prefix: plugverse_
  cors_origins:
    - http://localhost:3000
    - http://localhost:8000

frontend:
  enabled: true
  static_dir: ./static
